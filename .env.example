# --- AI Engine Configuration ---
# Your Google Gemini API Key for the Dungeon Master AI and QA Agents
GEMINI_API_KEY="your_gemini_api_key_here"

# --- GitHub MCP & Event-Driven Pipeline ---
# A GitHub Personal Access Token (PAT) with repository read/write access
# Required for the AI Implementer to create branches and push code via MCP
GITHUB_PAT="github_pat_your_token_here"

# The target repository for the AI developer team (e.g., your-username/dm_engine)
GITHUB_REPO="owner/repo_name"